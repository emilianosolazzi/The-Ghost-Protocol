# API server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hype_coin_dao

# Frontend shared settings
BASE_PATH=/

# Ghost protocol frontend
VITE_GHOST_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000
VITE_GHOST_PROTOCOL_RPC_URL=http://127.0.0.1:8545
VITE_GHOST_PROTOCOL_CHAIN_ID=31337
VITE_GHOST_PROTOCOL_EXPLORER_URL=http://localhost:3000
VITE_GHOST_ARCHIVE_API_URL=http://127.0.0.1:3000/api/ghost-archive

# Optional Pinata settings (never commit real secrets)
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud
